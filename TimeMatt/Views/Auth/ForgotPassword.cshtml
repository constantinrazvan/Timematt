@model ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - TextMatt</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <script>
        (function () {
            var stored = localStorage.getItem("fh-theme");
            var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            document.documentElement.setAttribute("data-bs-theme", stored || (systemDark ? "dark" : "light"));
        })();
    </script>

    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh; background-color: var(--fh-bg);">
        <div style="width: 100%; max-width: 380px;" class="px-3">
            <div class="text-center mb-4">
                <img src="~/logo.png" alt="TimeMatt" style="height: 96px; width: auto;" class="mb-2" />
                <h1 class="h4 fw-bold mb-1">Forgot your password?</h1>
                <p class="text-muted-fh mb-0">Enter your email and we'll send you a reset link.</p>
            </div>

            <div class="fh-card p-4">
                @if (Model.EmailSent)
                {
                    <div class="alert alert-success py-2 small mb-0" role="alert">
                        If an account exists for that email, we've sent a password reset link. Check your inbox (Mailpit at <a href="http://localhost:8025" target="_blank">localhost:8025</a> in this demo).
                    </div>
                }
                else
                {
                    <form asp-controller="Auth" asp-action="ForgotPassword" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Email</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" autofocus />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
                    </form>
                }
            </div>

            <div class="text-center text-muted-fh small mt-3">
                <a asp-controller="Auth" asp-action="Login" class="text-decoration-none">Back to sign in</a>
            </div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
