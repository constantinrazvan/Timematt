@model List<Account>
@{
    ViewData["Title"] = "Accounts";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 fw-bold mb-1">Accounts</h1>
        <p class="text-muted-fh mb-0">@Model.Count people with access to this workspace.</p>
    </div>
    <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="viewSwitcher">
            <i class="bi bi-list-ul me-1"></i> <span id="viewSwitcherLabel">List</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="#" data-view="list"><i class="bi bi-list-ul me-2"></i>List</a></li>
            <li><a class="dropdown-item" href="#" data-view="grid"><i class="bi bi-grid-3x3-gap me-2"></i>Grid</a></li>
        </ul>
    </div>
</div>

<div id="listView">
    <div class="fh-card">
        <div class="table-responsive">
            <table class="table fh-table mb-0 align-middle">
                <thead>
                    <tr>
                        <th style="padding-left: 1.25rem;">Name</th>
                        <th>Role</th>
                        <th>Company</th>
                        <th>Email</th>
                        <th>Last Active</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td style="padding-left: 1.25rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fh-avatar">@a.Avatar</span>
                                    <span class="fw-semibold">@a.Name</span>
                                </div>
                            </td>
                            <td><span class="fh-badge @a.Role.CssClass()">@a.Role.Label()</span></td>
                            <td class="text-muted-fh">@a.Company</td>
                            <td class="text-muted-fh">@a.Email</td>
                            <td class="text-muted-fh">@a.LastActive.ToString("MMM d, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="gridView" class="d-none">
    <div class="row g-3">
        @foreach (var a in Model)
        {
            <div class="col-sm-6 col-xl-3">
                <div class="fh-card h-100 p-3 text-center">
                    <span class="fh-avatar fh-avatar-lg mx-auto mb-3">@a.Avatar</span>
                    <div class="fw-semibold">@a.Name</div>
                    <div class="text-muted-fh small mb-2">@a.Company</div>
                    <span class="fh-badge @a.Role.CssClass()">@a.Role.Label()</span>
                    <div class="text-muted-fh small mt-3">@a.Email</div>
                    <div class="text-muted-fh" style="font-size: 0.72rem;">Active @a.LastActive.ToString("MMM d, yyyy")</div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const views = { list: document.getElementById('listView'), grid: document.getElementById('gridView') };
        const viewIcons = { list: 'bi-list-ul', grid: 'bi-grid-3x3-gap' };
        const viewLabels = { list: 'List', grid: 'Grid' };
        const viewSwitcher = document.getElementById('viewSwitcher');
        const viewSwitcherLabel = document.getElementById('viewSwitcherLabel');

        document.querySelectorAll('[data-view]').forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                const view = this.getAttribute('data-view');
                Object.keys(views).forEach(function (key) {
                    views[key].classList.toggle('d-none', key !== view);
                });
                viewSwitcherLabel.textContent = viewLabels[view];
                viewSwitcher.querySelector('i').className = 'bi ' + viewIcons[view] + ' me-1';
            });
        });
    </script>
}
