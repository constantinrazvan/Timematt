@model List<ProjectListItemViewModel>
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Projects</h1>
        <p class="text-muted-fh mb-0">@Model.Count projects across all clients.</p>
    </div>
    <button class="btn btn-primary rounded-3 px-3" type="button" data-bs-toggle="modal" data-bs-target="#newProjectModal">
        <i class="bi bi-plus-lg me-1"></i> New Project
    </button>
</div>

<div class="row g-3" id="projectsGrid">
    @foreach (var p in Model)
    {
        <div class="col-md-6 col-xl-4">
            <a asp-controller="Projects" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none text-reset">
                <div class="fh-card h-100 p-3">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <span style="width: 10px; height: 10px; border-radius: 50%; background-color: @p.Color; display: inline-block;"></span>
                            <span class="fw-semibold">@p.Name</span>
                        </div>
                        <span class="fh-badge @p.Status.CssClass()">@p.Status.Label()</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted-fh small">@p.ClientName</span>
                        <span class="fh-badge @p.PaymentType.CssClass()">@p.PaymentType.Label()</span>
                    </div>

                    <div class="fh-progress mb-1">
                        <div class="fh-progress-bar" style="width: @(p.Progress)%;"></div>
                    </div>
                    <div class="d-flex justify-content-between text-muted-fh mb-3" style="font-size: 0.78rem;">
                        <span>@p.Progress% complete</span>
                        <span>@p.HoursWorked.Hours()h logged</span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between pt-2 border-top" style="border-color: var(--fh-border) !important;">
                        <div>
                            <div class="text-muted-fh" style="font-size: 0.72rem;">@(p.PaymentType == PaymentType.Fixed ? "Fixed Budget" : "Rate")</div>
                            <div class="fw-semibold small">@(p.PaymentType == PaymentType.Fixed ? p.Budget.Money() : p.HourlyRate.Money() + "/hr")</div>
                        </div>
                        <div class="text-end">
                            <div class="text-muted-fh" style="font-size: 0.72rem;">Deadline</div>
                            <div class="fw-semibold small">@p.Deadline.ToString("MMM d, yyyy")</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<div class="modal fade" id="newProjectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <form id="newProjectForm">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">New Project</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex flex-column gap-3">
                    <div>
                        <label class="form-label small fw-semibold">Project Name</label>
                        <input type="text" class="form-control rounded-3" id="projectName" required />
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Client</label>
                        <select class="form-select rounded-3" id="projectClient" required>
                            @foreach (var c in (IEnumerable<Client>)ViewBag.Clients)
                            {
                                <option value="@c.Company">@c.Company</option>
                            }
                        </select>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Status</label>
                            <select class="form-select rounded-3" id="projectStatus">
                                <option value="Draft">Draft</option>
                                <option value="Active" selected>Active</option>
                                <option value="OnHold">On Hold</option>
                                <option value="Review">Review</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Payment Type</label>
                            <select class="form-select rounded-3" id="projectPaymentType">
                                <option value="Fixed">Fixed Price</option>
                                <option value="Hourly" selected>Hourly</option>
                            </select>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold" id="projectAmountLabel">Hourly Rate ($)</label>
                            <input type="number" class="form-control rounded-3" id="projectAmount" min="0" value="85" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Deadline</label>
                            <input type="date" class="form-control rounded-3" id="projectDeadline" required />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-3">Create Project</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const projectPaymentTypeSelect = document.getElementById('projectPaymentType');
        const projectAmountLabel = document.getElementById('projectAmountLabel');
        projectPaymentTypeSelect.addEventListener('change', function () {
            projectAmountLabel.textContent = this.value === 'Fixed' ? 'Fixed Budget ($)' : 'Hourly Rate ($)';
        });

        const projectColors = ['#6366f1', '#22c55e', '#0ea5e9', '#f59e0b', '#a855f7', '#ec4899'];

        document.getElementById('newProjectForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const name = document.getElementById('projectName').value.trim();
            const client = document.getElementById('projectClient').value;
            const status = document.getElementById('projectStatus').value;
            const paymentType = document.getElementById('projectPaymentType').value;
            const amount = parseFloat(document.getElementById('projectAmount').value) || 0;
            const deadlineRaw = document.getElementById('projectDeadline').value;
            if (!name || !client || !deadlineRaw) return;

            const deadline = new Date(deadlineRaw + 'T00:00:00');
            const deadlineLabel = deadline.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            const color = projectColors[Math.floor(Math.random() * projectColors.length)];
            const statusClassMap = { Draft: 'fh-badge-draft', Active: 'fh-badge-active', OnHold: 'fh-badge-onhold', Review: 'fh-badge-review' };
            const statusLabelMap = { Draft: 'Draft', Active: 'Active', OnHold: 'On Hold', Review: 'Review' };
            const amountLabel = paymentType === 'Fixed' ? 'Fixed Budget' : 'Rate';
            const amountValue = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(amount) + (paymentType === 'Hourly' ? '/hr' : '');
            const paymentBadgeClass = paymentType === 'Fixed' ? 'fh-badge-fixed' : 'fh-badge-hourly';
            const paymentBadgeLabel = paymentType === 'Fixed' ? 'Fixed Price' : 'Hourly';

            const col = document.createElement('div');
            col.className = 'col-md-6 col-xl-4';
            col.innerHTML = `
                <div class="fh-card h-100 p-3">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <span style="width: 10px; height: 10px; border-radius: 50%; background-color: ${color}; display: inline-block;"></span>
                            <span class="fw-semibold">${name}</span>
                        </div>
                        <span class="fh-badge ${statusClassMap[status]}">${statusLabelMap[status]}</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-muted-fh small">${client}</span>
                        <span class="fh-badge ${paymentBadgeClass}">${paymentBadgeLabel}</span>
                    </div>
                    <div class="fh-progress mb-1"><div class="fh-progress-bar" style="width: 0%;"></div></div>
                    <div class="d-flex justify-content-between text-muted-fh mb-3" style="font-size: 0.78rem;">
                        <span>0% complete</span>
                        <span>0h logged</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between pt-2 border-top" style="border-color: var(--fh-border) !important;">
                        <div>
                            <div class="text-muted-fh" style="font-size: 0.72rem;">${amountLabel}</div>
                            <div class="fw-semibold small">${amountValue}</div>
                        </div>
                        <div class="text-end">
                            <div class="text-muted-fh" style="font-size: 0.72rem;">Deadline</div>
                            <div class="fw-semibold small">${deadlineLabel}</div>
                        </div>
                    </div>
                </div>
            `;
            document.getElementById('projectsGrid').prepend(col);

            this.reset();
            document.getElementById('projectAmount').value = 85;
            bootstrap.Modal.getInstance(document.getElementById('newProjectModal')).hide();
        });
    </script>
}
