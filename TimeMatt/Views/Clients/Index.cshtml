@model List<ClientListItemViewModel>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Clients</h1>
        <p class="text-muted-fh mb-0">@Model.Count clients across all your active work.</p>
    </div>
    <button class="btn btn-primary rounded-3 px-3" type="button" data-bs-toggle="modal" data-bs-target="#newClientModal">
        <i class="bi bi-plus-lg me-1"></i> New Client
    </button>
</div>

<div class="fh-card">
    <div class="table-responsive">
        <table class="table fh-table mb-0 align-middle" id="clientsTable">
            <thead>
                <tr>
                    <th style="padding-left: 1.25rem;">Client</th>
                    <th>Company</th>
                    <th>Email</th>
                    <th>Active Projects</th>
                    <th>Total Worked Hours</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr class="fh-table-row-link" onclick="window.location='@Url.Action("Details", new { id = client.Id })'">
                        <td style="padding-left: 1.25rem;">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fh-avatar">@client.Avatar</span>
                                <span class="fw-semibold">@client.Name</span>
                            </div>
                        </td>
                        <td>@client.Company</td>
                        <td class="text-muted-fh">@client.Email</td>
                        <td>@client.ActiveProjects</td>
                        <td>@client.TotalWorkedHours.Hours()h</td>
                        <td class="text-end" style="padding-right: 1.25rem;">
                            <i class="bi bi-chevron-right text-muted-fh"></i>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="newClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <form id="newClientForm">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title fw-bold">New Client</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex flex-column gap-3">
                    <div class="alert alert-danger py-2 small mb-0 d-none" id="newClientError"></div>
                    <div>
                        <label class="form-label small fw-semibold">Name</label>
                        <input type="text" class="form-control rounded-3" id="clientName" required />
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Company</label>
                        <input type="text" class="form-control rounded-3" id="clientCompany" required />
                    </div>
                    <div>
                        <label class="form-label small fw-semibold">Email</label>
                        <input type="email" class="form-control rounded-3" id="clientEmail" required />
                    </div>
                    <p class="text-muted-fh small mb-0">
                        <i class="bi bi-envelope me-1"></i>An invite email with a temporary password and a 48-hour setup link will be sent to this address.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-3" id="newClientSubmit">Send Invite</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('newClientForm').addEventListener('submit', async function (e) {
            e.preventDefault();

            const errorBox = document.getElementById('newClientError');
            const submitBtn = document.getElementById('newClientSubmit');
            errorBox.classList.add('d-none');

            const name = document.getElementById('clientName').value.trim();
            const company = document.getElementById('clientCompany').value.trim();
            const email = document.getElementById('clientEmail').value.trim();
            if (!name || !company || !email) return;

            const token = this.querySelector('input[name="__RequestVerificationToken"]').value;

            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending invite...';

            try {
                const response = await fetch('@Url.Action("Create", "Clients")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: new URLSearchParams({ Name: name, Company: company, Email: email, __RequestVerificationToken: token })
                });

                if (!response.ok) {
                    const problem = await response.json().catch(() => null);
                    errorBox.textContent = problem?.Email?.[0] || problem?.[0] || 'Could not create this client. Please check the details and try again.';
                    errorBox.classList.remove('d-none');
                    return;
                }

                const data = await response.json();
                const row = document.createElement('tr');
                row.className = 'fh-table-row-link';
                row.onclick = function () { window.location = '@Url.Action("Details")/' + data.client.id; };
                row.innerHTML = `
                    <td style="padding-left: 1.25rem;">
                        <div class="d-flex align-items-center gap-2">
                            <span class="fh-avatar">${data.client.avatar}</span>
                            <span class="fw-semibold">${data.client.name}</span>
                        </div>
                    </td>
                    <td>${data.client.company}</td>
                    <td class="text-muted-fh">${data.client.email}</td>
                    <td>0</td>
                    <td>0h</td>
                    <td class="text-end" style="padding-right: 1.25rem;"><i class="bi bi-chevron-right text-muted-fh"></i></td>
                `;
                document.querySelector('#clientsTable tbody').prepend(row);

                this.reset();
                bootstrap.Modal.getInstance(document.getElementById('newClientModal')).hide();
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Invite';
            }
        });
    </script>
}
