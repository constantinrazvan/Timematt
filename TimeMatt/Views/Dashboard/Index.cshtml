@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Good to see you, Alex</h1>
        <p class="text-muted-fh mb-0">Here's what's happening across your projects today.</p>
    </div>
    <a asp-controller="TimeTracking" asp-action="Index" class="btn btn-primary rounded-3 px-3">
        <i class="bi bi-stopwatch-fill me-1"></i> Start Timer
    </a>
</div>

<div class="fh-stat-grid mb-4">
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(99,102,241,0.12); color: #6366f1;"><i class="bi bi-kanban-fill"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Active Projects</div>
            <div class="fh-stat-value">@Model.ActiveProjects</div>
        </div>
    </div>
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(14,165,233,0.12); color: #0284c7;"><i class="bi bi-people-fill"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Total Clients</div>
            <div class="fh-stat-value">@Model.TotalClients</div>
        </div>
    </div>
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(34,197,94,0.12); color: #16a34a;"><i class="bi bi-clock-fill"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Hours Today</div>
            <div class="fh-stat-value">@Model.HoursToday.Hours()h</div>
        </div>
    </div>
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(245,158,11,0.12); color: #b45309;"><i class="bi bi-calendar-week-fill"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Hours This Week</div>
            <div class="fh-stat-value">@Model.HoursThisWeek.Hours()h</div>
        </div>
    </div>
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(168,85,247,0.12); color: #9333ea;"><i class="bi bi-cash-stack"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Est. Revenue</div>
            <div class="fh-stat-value" title="@Model.EstimatedRevenue.Money()">@Model.EstimatedRevenue.Money()</div>
        </div>
    </div>
    <div class="fh-stat-card fh-stat-card-flex">
        <div class="fh-stat-icon" style="background: rgba(239,68,68,0.12); color: #dc2626;"><i class="bi bi-list-check"></i></div>
        <div class="fh-stat-body">
            <div class="text-muted-fh small">Pending Tasks</div>
            <div class="fh-stat-value">@Model.PendingTasks</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12 col-lg-7">
        <div class="fh-card h-100">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Hours Worked This Week</h2>
            </div>
            <div class="fh-card-body">
                <canvas id="weeklyHoursChart" height="110"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-5">
        <div class="fh-card h-100">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Revenue by Project</h2>
            </div>
            <div class="fh-card-body">
                <canvas id="revenueByProjectChart" height="110"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-4">
        <div class="fh-card h-100">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Recent Activity</h2>
            </div>
            <div class="fh-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var item in Model.RecentActivity)
                    {
                        <div class="d-flex gap-3">
                            <div class="fh-activity-icon" style="background: rgba(99,102,241,0.12); color: var(--bs-@item.IconColor);">
                                <i class="bi @item.Icon"></i>
                            </div>
                            <div>
                                <div class="small">@item.Text</div>
                                <div class="text-muted-fh" style="font-size: 0.75rem;">@item.Timestamp.ToString("MMM d, h:mm tt")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="fh-card h-100">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Upcoming Deadlines</h2>
            </div>
            <div class="fh-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var d in Model.UpcomingDeadlines)
                    {
                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@d.ProjectId" class="d-flex align-items-center justify-content-between text-decoration-none text-reset">
                            <div>
                                <div class="fw-semibold small">@d.ProjectName</div>
                                <div class="text-muted-fh" style="font-size: 0.78rem;">@d.ClientName</div>
                            </div>
                            <span class="fh-badge @(d.DaysLeft <= 3 ? "fh-badge-urgent" : "fh-badge-review")">
                                @(d.DaysLeft == 0 ? "Today" : d.DaysLeft + "d left")
                            </span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="fh-card h-100">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Recent Projects</h2>
                <a asp-controller="Projects" asp-action="Index" class="small text-decoration-none">View all</a>
            </div>
            <div class="fh-card-body">
                <div class="d-flex flex-column gap-3">
                    @foreach (var p in Model.RecentProjects)
                    {
                        <a asp-controller="Projects" asp-action="Details" asp-route-id="@p.Id" class="text-decoration-none text-reset">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <div class="d-flex align-items-center gap-2">
                                    <span style="width: 8px; height: 8px; border-radius: 50%; background-color: @p.Color; display: inline-block;"></span>
                                    <span class="fw-semibold small">@p.Name</span>
                                </div>
                                <span class="fh-badge @p.Status.CssClass()">@p.Status.Label()</span>
                            </div>
                            <div class="fh-progress">
                                <div class="fh-progress-bar" style="width: @(p.Progress)%;"></div>
                            </div>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        const fhTextColor = getComputedStyle(document.documentElement).getPropertyValue('--fh-text-muted').trim();
        Chart.defaults.font.family = "Inter, sans-serif";
        Chart.defaults.color = fhTextColor || '#6b7280';

        new Chart(document.getElementById('weeklyHoursChart'), {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.WeekDayLabels)),
                datasets: [{
                    label: 'Hours',
                    data: @Html.Raw(Json.Serialize(Model.WeekDayHours)),
                    backgroundColor: '#6366f1',
                    borderRadius: 6,
                    maxBarThickness: 36
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(120,120,130,0.12)' } },
                    x: { grid: { display: false } }
                }
            }
        });

        new Chart(document.getElementById('revenueByProjectChart'), {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.RevenueProjectLabels)),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.RevenueProjectValues)),
                    backgroundColor: ['#6366f1', '#22c55e', '#0ea5e9', '#f59e0b', '#a855f7', '#ec4899'],
                    borderWidth: 0
                }]
            },
            options: {
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, padding: 14 } } },
                cutout: '65%'
            }
        });
    </script>
}
