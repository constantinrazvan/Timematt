@model ReportExportViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>TextMatt Report - @Model.GeneratedAt.ToString("MMM d, yyyy")</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            color: #1a1d23;
            margin: 0;
            padding: 32px 40px;
        }
        h1 { font-size: 1.5rem; margin: 0 0 4px; }
        .subtitle { color: #6b7280; font-size: 0.85rem; margin: 0 0 24px; }
        .brand { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
        .brand-mark { width: 30px; height: 30px; background: #7a4c8b; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; }
        .summary-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 32px; }
        .summary-card { border: 1px solid #e6e8ec; padding: 12px 14px; }
        .summary-card .label { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.03em; }
        .summary-card .value { font-size: 1.2rem; font-weight: 700; margin-top: 2px; }
        h2 { font-size: 1rem; margin: 28px 0 10px; border-bottom: 2px solid #7a4c8b; padding-bottom: 6px; }
        table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
        th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #e6e8ec; }
        th { color: #6b7280; text-transform: uppercase; font-size: 0.68rem; letter-spacing: 0.03em; }
        .badge { display: inline-block; padding: 2px 8px; font-size: 0.7rem; font-weight: 600; border: 1px solid #d0d3d9; }
        .print-actions { margin-bottom: 24px; }
        .print-actions button { background: #7a4c8b; color: #fff; border: none; padding: 8px 16px; font-size: 0.85rem; cursor: pointer; }
        @@media print {
            .print-actions { display: none; }
            body { padding: 0; }
        }
    </style>
</head>
<body>
    <div class="print-actions">
        <button onclick="window.print()">Print / Save as PDF</button>
    </div>

    <div class="brand">
        <strong>TextMatt</strong>
    </div>
    <h1>Workspace Report</h1>
    <p class="subtitle">Generated @Model.GeneratedAt.ToString("MMMM d, yyyy 'at' h:mm tt")</p>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="label">Active Projects</div>
            <div class="value">@Model.ActiveProjects</div>
        </div>
        <div class="summary-card">
            <div class="label">Total Clients</div>
            <div class="value">@Model.TotalClients</div>
        </div>
        <div class="summary-card">
            <div class="label">Est. Revenue</div>
            <div class="value">@Model.EstimatedRevenue.Money()</div>
        </div>
        <div class="summary-card">
            <div class="label">Pending Tasks</div>
            <div class="value">@Model.PendingTasks</div>
        </div>
        <div class="summary-card">
            <div class="label">Hours This Month</div>
            <div class="value">@Model.HoursThisMonth.Hours()h</div>
        </div>
    </div>

    <h2>Clients (@Model.Clients.Count)</h2>
    <table>
        <thead>
            <tr><th>Name</th><th>Company</th><th>Email</th><th>Active Projects</th><th>Total Hours</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Clients)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Company</td>
                    <td>@c.Email</td>
                    <td>@c.ActiveProjects</td>
                    <td>@c.TotalHours.Hours()h</td>
                </tr>
            }
        </tbody>
    </table>

    <h2>Projects (@Model.Projects.Count)</h2>
    <table>
        <thead>
            <tr><th>Name</th><th>Client</th><th>Status</th><th>Payment</th><th>Progress</th><th>Hours</th><th>Revenue</th><th>Deadline</th></tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Projects)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.ClientName</td>
                    <td><span class="badge">@p.Status.Label()</span></td>
                    <td><span class="badge">@p.PaymentType.Label()</span></td>
                    <td>@p.Progress%</td>
                    <td>@p.HoursWorked.Hours()h</td>
                    <td>@p.RevenueToDate.Money()</td>
                    <td>@p.Deadline.ToString("MMM d, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>

    <h2>Tasks (@Model.Tasks.Count)</h2>
    <table>
        <thead>
            <tr><th>Title</th><th>Project</th><th>Status</th><th>Priority</th><th>Est. Hours</th><th>Worked Hours</th><th>Deadline</th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Tasks)
            {
                <tr>
                    <td>@t.Title</td>
                    <td>@t.ProjectName</td>
                    <td><span class="badge">@t.Column.ColumnLabel()</span></td>
                    <td><span class="badge">@t.Priority</span></td>
                    <td>@t.EstimatedHours.Hours()h</td>
                    <td>@t.WorkedHours.Hours()h</td>
                    <td>@t.Deadline.ToString("MMM d, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
