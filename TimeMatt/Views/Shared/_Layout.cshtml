@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    bool IsActive(string controller) => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FreelanceHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <script>
        (function () {
            var stored = localStorage.getItem("fh-theme");
            var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            document.documentElement.setAttribute("data-bs-theme", stored || (systemDark ? "dark" : "light"));
        })();
    </script>

    <div class="fh-shell">
        <div id="fhSidebarOverlay" class="d-none position-fixed top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.4); z-index: 1025;"></div>

        <aside class="fh-sidebar" id="fhSidebar">
            <div class="fh-sidebar-brand">
                <span class="fh-logo-mark"><i class="bi bi-lightning-charge-fill"></i></span>
                <span>FreelanceHub</span>
            </div>
            <nav class="fh-sidebar-nav">
                <a class="fh-nav-link @(IsActive("Dashboard") ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>
                <a class="fh-nav-link @(IsActive("Clients") ? "active" : "")" asp-controller="Clients" asp-action="Index">
                    <i class="bi bi-people-fill"></i> Clients
                </a>
                <a class="fh-nav-link @(IsActive("Projects") ? "active" : "")" asp-controller="Projects" asp-action="Index">
                    <i class="bi bi-kanban-fill"></i> Projects
                </a>
                <a class="fh-nav-link @(IsActive("Tasks") ? "active" : "")" asp-controller="Tasks" asp-action="Index">
                    <i class="bi bi-check2-square"></i> Tasks
                </a>
                <a class="fh-nav-link @(IsActive("TimeTracking") ? "active" : "")" asp-controller="TimeTracking" asp-action="Index">
                    <i class="bi bi-stopwatch-fill"></i> Time Tracking
                </a>
                <a class="fh-nav-link @(IsActive("Reports") ? "active" : "")" asp-controller="Reports" asp-action="Index">
                    <i class="bi bi-bar-chart-line-fill"></i> Reports
                </a>
                <a class="fh-nav-link @(IsActive("Settings") ? "active" : "")" asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-gear-fill"></i> Settings
                </a>
            </nav>
            <div class="fh-sidebar-footer d-flex align-items-center gap-2">
                <span class="fh-avatar fh-avatar-sm">AM</span>
                <div>
                    <div class="text-white fw-semibold" style="font-size: 0.8rem;">Alex Morgan</div>
                    <div style="font-size: 0.72rem;">Freelancer</div>
                </div>
            </div>
        </aside>

        <div class="fh-main">
            <header class="fh-topbar">
                <div class="d-flex align-items-center gap-3">
                    <button class="fh-icon-btn d-lg-none" id="sidebarToggle" type="button" aria-label="Toggle sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="fh-search d-none d-md-flex align-items-center gap-2">
                        <i class="bi bi-search text-muted-fh"></i>
                        <input type="text" placeholder="Search projects, clients, tasks..." />
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="fh-icon-btn" id="themeToggle" type="button" aria-label="Toggle theme">
                        <i class="bi bi-moon-stars" id="themeToggleIcon"></i>
                    </button>
                    <div class="dropdown">
                        <button class="fh-icon-btn position-relative" id="notificationsToggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Notifications">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end fh-notifications-menu p-0" aria-labelledby="notificationsToggle">
                            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom" style="border-color: var(--fh-border) !important;">
                                <span class="fw-semibold small">Notifications</span>
                                <span class="fh-kanban-count">3 new</span>
                            </div>
                            <a class="dropdown-item fh-notification-item" href="#" onclick="return false;">
                                <div class="fh-activity-icon" style="background: rgba(239,68,68,0.12); color: var(--bs-danger);"><i class="bi bi-alarm"></i></div>
                                <div>
                                    <div class="small">"Checkout Flow" is due in 3 days on E-commerce Redesign</div>
                                    <div class="text-muted-fh" style="font-size: 0.72rem;">2 hours ago</div>
                                </div>
                            </a>
                            <a class="dropdown-item fh-notification-item" href="#" onclick="return false;">
                                <div class="fh-activity-icon" style="background: rgba(99,102,241,0.12); color: var(--bs-primary);"><i class="bi bi-chat-left-text"></i></div>
                                <div>
                                    <div class="small">Sarah Bennett commented on Corporate Website</div>
                                    <div class="text-muted-fh" style="font-size: 0.72rem;">6 hours ago</div>
                                </div>
                            </a>
                            <a class="dropdown-item fh-notification-item" href="#" onclick="return false;">
                                <div class="fh-activity-icon" style="background: rgba(34,197,94,0.12); color: var(--bs-success);"><i class="bi bi-check2-circle"></i></div>
                                <div>
                                    <div class="small">Payment Gateway Testing marked as Done</div>
                                    <div class="text-muted-fh" style="font-size: 0.72rem;">Yesterday</div>
                                </div>
                            </a>
                            <div class="text-center py-2 border-top" style="border-color: var(--fh-border) !important;">
                                <a href="#" class="small text-decoration-none" onclick="return false;">View all notifications</a>
                            </div>
                        </div>
                    </div>
                    <span class="fh-avatar">AM</span>
                </div>
            </header>

            <main class="fh-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
