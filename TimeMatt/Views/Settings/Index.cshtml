@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Settings</h1>
    <p class="text-muted-fh mb-0">Manage your profile, workspace and appearance preferences.</p>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="fh-card mb-3">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Profile</h2>
            </div>
            <div class="fh-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Name</label>
                        <input type="text" class="form-control rounded-3" value="@Model.Name" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Email</label>
                        <input type="email" class="form-control rounded-3" value="@Model.Email" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Company</label>
                        <input type="text" class="form-control rounded-3" value="@Model.Company" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Timezone</label>
                        <select class="form-select rounded-3">
                            <option selected>@Model.Timezone</option>
                            <option>(UTC+00:00) London</option>
                            <option>(UTC+01:00) Berlin, Paris</option>
                            <option>(UTC-08:00) Pacific Time</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="fh-card">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Preferences</h2>
            </div>
            <div class="fh-card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Currency</label>
                        <select class="form-select rounded-3">
                            <option selected>@Model.Currency</option>
                            <option>EUR</option>
                            <option>GBP</option>
                            <option>RON</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Theme</label>
                        <select class="form-select rounded-3">
                            <option selected>@Model.Theme</option>
                            <option>Light</option>
                            <option>Dark</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-3 mb-3">
            <button class="btn btn-primary rounded-3 px-4" type="button">Save Changes</button>
        </div>

        <div class="fh-card">
            <div class="fh-card-header">
                <h2 class="fh-section-title">Change Password</h2>
            </div>
            <div class="fh-card-body">
                @{
                    var changePassword = (ChangePasswordViewModel)ViewBag.ChangePassword;
                }
                @if (changePassword.Success)
                {
                    <div class="alert alert-success py-2 small" role="alert">Your password was updated successfully.</div>
                }
                @if (!string.IsNullOrEmpty(changePassword.ErrorMessage))
                {
                    <div class="alert alert-danger py-2 small" role="alert">@changePassword.ErrorMessage</div>
                }
                <form asp-controller="Settings" asp-action="ChangePassword" method="post">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Current Password</label>
                            <input type="password" class="form-control rounded-3" name="CurrentPassword" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">New Password</label>
                            <input type="password" class="form-control rounded-3" name="NewPassword" required minlength="8" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-semibold">Confirm New Password</label>
                            <input type="password" class="form-control rounded-3" name="ConfirmPassword" required minlength="8" />
                        </div>
                    </div>
                    <div class="d-flex justify-content-end mt-3">
                        <button class="btn btn-outline-secondary rounded-3 px-4" type="submit">Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="fh-card p-4 text-center">
            <span class="fh-avatar fh-avatar-lg mx-auto mb-3">AM</span>
            <h2 class="h5 fw-bold mb-0">@Model.Name</h2>
            <div class="text-muted-fh mb-1">@Model.Company</div>
            <div class="text-muted-fh small">@Model.Email</div>
        </div>
    </div>
</div>
